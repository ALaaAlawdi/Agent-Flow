# Agent-Flow environment configuration
# Copy this file to `.env` and fill in real values.

# --- OpenAI (default provider) ---
# Required for OpenAI-backed agents (gpt-4o, gpt-4o-mini, o1, ...).
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the OpenAI base URL (e.g. Azure OpenAI, OpenRouter, LiteLLM proxy).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: default model when a request does not specify one.
# AGENT_FLOW_DEFAULT_MODEL=gpt-4o-mini

# --- Other providers (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# DeepSeek (alternative LLM)
# DEEPSEEK_API_KEY=sk-deepseek-...
# HERMES_DEFAULT_MODEL=deepseek-v4-pro
# HERMES_DEFAULT_PROVIDER=deepseek

# --- Agent-Flow runtime ---
# Trusted-gateway capability secret (required only for the packets/complete flow).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AGENT_FLOW_CAPABILITY_SECRET=

# --- API server ---
# AGENT_FLOW_HOST=0.0.0.0
# AGENT_FLOW_PORT=8000
# API_LOG_LEVEL=info

# Authentication: if set, all API requests require X-API-Key header
# API_KEY=

# --- Database ---
# DATABASE_URL=sqlite:///data/agent_flow.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:pass@db:5432/agent_flow

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://localhost:8000

# --- CORS ---
# CORS_ORIGINS=*
# For production: CORS_ORIGINS=https://agent-flow.dev,https://app.agent-flow.dev

# --- Rate limiting ---
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_PER_HOUR=1000
