# Agent-Flow Production Environment
# Copy to .env and fill in values

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# DeepSeek (default LLM)
DEEPSEEK_API_KEY=sk-deepseek-...

# OpenAI (alternative LLM)
OPENAI_API_KEY=sk-openai-...

# Default model
HERMES_DEFAULT_MODEL=deepseek-v4-pro
HERMES_DEFAULT_PROVIDER=deepseek

# --- Authentication (optional) ---
# If set, all API requests require X-API-Key header
API_KEY=

# --- Database ---
DATABASE_URL=sqlite:///data/agent_flow.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:pass@db:5432/agent_flow

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# In production behind reverse proxy:
# NEXT_PUBLIC_API_URL=https://api.agent-flow.dev

# --- CORS ---
CORS_ORIGINS=*
# For production:
# CORS_ORIGINS=https://agent-flow.dev,https://app.agent-flow.dev

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# --- Data Paths ---
PERSISTENCE_DIR=/opt/data/hermes-brain/vault
DATA_DIR=/opt/data/Agent-Flow